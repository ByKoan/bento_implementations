#######################################################
# DataBase #
POCKETBASE_URL="http://host.docker.internal:8090" # DB URL
TEMP_TOKEN="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJjb2xsZWN0aW9uSWQiOiJwYmNfMzE0MjYzNTgyMyIsImV4cCI6MTc3MzMxOTY0MCwiaWQiOiJyMGp5OWp6Z3A4anBoZDEiLCJyZWZyZXNoYWJsZSI6dHJ1ZSwidHlwZSI6ImF1dGgifQ.Uc_KggUDbweIm8YPkQct8JN2Snjbkxhp-XQ6z-CBA3I"
DB_URL="http://127.0.0.1:8090"
BENTHOS_URL="http://benthos:4197/ingest" # Bento URL
#######################################################
# Collections #
AUTHENTICATION_COLLECTION="_superusers"
COLLECTION_READINGS="readings" # Collection where data will be stored in Pocketbase
COLLECTION_URGENT="urgent_alerts" 
#######################################################
# Authenticacion configuration for DB #
# It recomended only to create 1 user for al devices, for avoid problems with authentication and tokens#
POCKETBASE_USER="admin@example.com"
POCKETBASE_PASSWORD="koan_12345"
POCKETBASE_SUPERUSER="koan@koan.com"
POCKETBASE_SUPERPASSWORD="koan_12345"
POCKETBASE_TOKEN=$(python3 ./scripts/obtener_token.py) # Require a _superuser tocken of PocketBase
BATCH_SIZE=5 # Number of messages to batch before sending to Pocketbase
FLUSH_INTERVAL=5 # Time in seconds to wait before flushing the batch to Pocketbase, even if the batch size is not reached
#######################################################
# Configuracion de MQTT #
MQTT_BROKER="mqtt_broker"
MQTT_BROKER_LOCAL="localhost"
MQTT_PORT=1883
MQTT_TOPIC="devices/+/readings"
MQTT_ERROR_TOPIC="errors"
MQTT_PUBLISH_TOPIC_ALERTS="alerts"
#######################################################
# Disk configuration #
MAX_RETRIES=5
BASE_DELAY=1
MAX_DELAY=30
QUEUE_FILE="/app/data/pending_readings.log" # File where pending readings will be stored in case of failure
#######################################################
# Sensors id for testing with the send_random_mqtt.py script #
TEMP_ID="28aqeb8k92jukhm"
BATTERY_ID="j31qmwn3bmsvnev"
STATUS_ID="7cf6zursni1d5o9"
HAS_PALLET_ID="vn9b6xdrusloced"
#######################################################
# Edge proccesor #
# Invalid Alerts: #
BATTERY_MINIMUM_INVALID=0
BATTERY_MAXIMUM_INVALID=100
TEMP_MINIMUM_INVALID=0
TEMP_MAXIMUM_INVALID=80
# Normal Alerts: #
BATTERY_THRESHOLD=20
TEMP_THRESHOLD=70
#######################################################